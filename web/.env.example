# Prisma datasource — SILO multi-tenant: schema tenant di-pin lewat `?schema=`.
# Host dev: Postgres container terekspos di 127.0.0.1:3022 (compose 3022:5432).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/antigravity_pos?schema=tenant_<slug>"


# Better Auth — generate: node -e "console.log(require(\"crypto\").randomBytes(32).toString(\"hex\"))"
BETTER_AUTH_SECRET="ganti_dengan_secret_acak_min_32_byte"
BETTER_AUTH_URL="http://localhost:3000"
