generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model categories {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  items       items[]
}

model customers {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar(255)
  phone        String?        @db.VarChar(255)
  email        String?        @db.VarChar(255)
  address      String?
  points       Int?           @default(0)
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime       @default(now()) @db.Timestamptz(6)
  transactions transactions[]
}

model discounts {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(255)
  type       String   @db.VarChar(255)
  value      Decimal  @db.Decimal(14, 2)
  max_value  Decimal? @db.Decimal(14, 2)
  is_active  Boolean? @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model items {
  id                Int                 @id @default(autoincrement())
  code              String              @unique(map: "items_code_unique") @db.VarChar(255)
  name              String              @db.VarChar(255)
  category_id       Int?
  unit              String?             @default("pcs") @db.VarChar(255)
  hpp               Decimal?            @default(0) @db.Decimal(14, 2)
  price             Decimal             @db.Decimal(14, 2)
  min_stock         Int?                @default(0)
  supplier_id       Int?
  stock             Int?                @default(0)
  is_active         Boolean?            @default(true)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  internal_id       String?             @unique(map: "items_internal_id_unique") @db.VarChar(255)
  variant_name      String?             @db.VarChar(255)
  brand_name        String?             @db.VarChar(255)
  condition         String?             @db.VarChar(255)
  image_url         String?
  categories        categories?         @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "items_category_id_foreign")
  suppliers         suppliers?          @relation(fields: [supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "items_supplier_id_foreign")
  po_items          po_items[]
  stock_adjustments stock_adjustments[]
  stock_lots        stock_lots[]
  transaction_items transaction_items[]
  void_items        void_items[]
}

model stock_lots {
  id              Int                      @id @default(autoincrement())
  item_id         Int
  source_type     String                   @db.VarChar(20)
  po_id           Int?
  supplier_id     Int?
  unit_cost       Decimal                  @db.Decimal(14, 2)
  qty_received    Int
  qty_remaining   Int
  status          String                   @default("ACTIVE") @db.VarChar(20)
  received_at     DateTime                 @default(now()) @db.Timestamptz(6)
  created_at      DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at      DateTime                 @default(now()) @db.Timestamptz(6)
  expires_at      DateTime?                @db.Timestamptz(6)
  consumptions    stock_lot_consumptions[]
  items           items                    @relation(fields: [item_id], references: [id], onDelete: Cascade)
  purchase_orders purchase_orders?         @relation(fields: [po_id], references: [id])
  suppliers       suppliers?               @relation(fields: [supplier_id], references: [id])
}

model stock_lot_consumptions {
  id                  Int               @id @default(autoincrement())
  transaction_item_id Int
  stock_lot_id        Int
  qty                 Int
  unit_cost           Decimal           @db.Decimal(14, 2)
  settled             Boolean           @default(false)
  created_at          DateTime          @default(now()) @db.Timestamptz(6)
  updated_at          DateTime          @default(now()) @db.Timestamptz(6)
  stock_lots          stock_lots        @relation(fields: [stock_lot_id], references: [id], onDelete: Cascade)
  transaction_items   transaction_items @relation(fields: [transaction_item_id], references: [id], onDelete: Cascade)
}

model knex_migrations {
  id             Int       @id @default(autoincrement())
  name           String?   @db.VarChar(255)
  batch          Int?
  migration_time DateTime? @db.Timestamptz(6)
}

model knex_migrations_lock {
  index     Int  @id @default(autoincrement())
  is_locked Int?
}

model payment_types {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar(255)
  type         String         @db.VarChar(255)
  is_active    Boolean?       @default(true)
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime       @default(now()) @db.Timestamptz(6)
  transactions transactions[]
}

model po_items {
  id              Int              @id @default(autoincrement())
  po_id           Int?
  item_id         Int?
  qty             Int
  cost            Decimal          @db.Decimal(14, 2)
  subtotal        Decimal          @db.Decimal(14, 2)
  items           items?           @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "po_items_item_id_foreign")
  purchase_orders purchase_orders? @relation(fields: [po_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "po_items_po_id_foreign")
}

model promos {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  type         String    @db.VarChar(255)
  value        Decimal   @db.Decimal(14, 2)
  min_purchase Decimal?  @default(0) @db.Decimal(14, 2)
  start_date   DateTime? @db.Timestamptz(6)
  end_date     DateTime? @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)
}

model purchase_orders {
  id               Int          @id @default(autoincrement())
  po_number        String       @unique(map: "purchase_orders_po_number_unique") @db.VarChar(255)
  supplier_id      Int?
  user_id          Int?
  status           String?      @default("pending") @db.VarChar(255)
  total_amount     Decimal?     @default(0) @db.Decimal(14, 2)
  notes            String?
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  updated_at       DateTime     @default(now()) @db.Timestamptz(6)
  due_date         DateTime?    @db.Timestamptz(6)
  payment_method   String?      @default("CASH") @db.VarChar(50)
  payment_status   String?      @default("PAID") @db.VarChar(50)
  consignment_days Int?
  payables         payables[]
  po_items         po_items[]
  suppliers        suppliers?   @relation(fields: [supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "purchase_orders_supplier_id_foreign")
  users            users?       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "purchase_orders_user_id_foreign")
  stock_lots       stock_lots[]
}

model payables {
  id               Int                @id @default(autoincrement())
  supplier_id      Int
  po_id            Int?
  type             String             @db.VarChar(50)
  total_debt       Decimal            @db.Decimal(14, 2)
  amount_paid      Decimal            @default(0) @db.Decimal(14, 2)
  status           String             @default("OPEN") @db.VarChar(50)
  due_date         DateTime?          @db.Timestamptz(6)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  payable_payments payable_payments[]
  purchase_orders  purchase_orders?   @relation(fields: [po_id], references: [id], onDelete: Cascade)
  suppliers        suppliers          @relation(fields: [supplier_id], references: [id], onDelete: Cascade)
}

model payable_payments {
  id             Int      @id @default(autoincrement())
  payable_id     Int
  payment_date   DateTime @default(now()) @db.Timestamptz(6)
  amount         Decimal  @db.Decimal(14, 2)
  payment_method String?  @db.VarChar(50)
  reference_no   String?  @db.VarChar(255)
  notes          String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)
  payables       payables @relation(fields: [payable_id], references: [id], onDelete: Cascade)
}

model receipt_settings {
  id            Int      @id @default(autoincrement())
  header        String?
  footer        String?
  show_tax      Boolean? @default(true)
  show_discount Boolean? @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)
}

model stock_adjustments {
  id         Int      @id @default(autoincrement())
  item_id    Int?
  user_id    Int?
  qty_change Int
  reason     String   @db.VarChar(255)
  notes      String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  items      items?   @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "stock_adjustments_item_id_foreign")
  users      users?   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "stock_adjustments_user_id_foreign")
}

model expense_categories {
  id           Int        @id @default(autoincrement())
  name         String     @db.VarChar(255)
  account_code String?    @db.VarChar(50)
  is_active    Boolean    @default(true)
  created_at   DateTime   @default(now()) @db.Timestamptz(6)
  updated_at   DateTime   @default(now()) @db.Timestamptz(6)
  description  String?
  expenses     expenses[]
}

model expenses {
  id                 Int                @id @default(autoincrement())
  category_id        Int
  amount             Decimal            @db.Decimal(14, 2)
  notes              String?
  expense_date       DateTime           @db.Date
  created_by         Int
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime           @default(now()) @db.Timestamptz(6)
  expense_categories expense_categories @relation(fields: [category_id], references: [id])
  users              users              @relation(fields: [created_by], references: [id])
}

model store_settings {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(255)
  address    String?
  phone      String?  @db.VarChar(255)
  logo       String?  @db.VarChar(255)
  currency   String?  @default("IDR") @db.VarChar(255)
  timezone   String?  @default("Asia/Jakarta") @db.VarChar(255)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  email      String?  @db.VarChar(255)
}

model suppliers {
  id               Int               @id @default(autoincrement())
  name             String            @db.VarChar(255)
  contact          String?           @db.VarChar(255)
  phone            String?           @db.VarChar(255)
  email            String?           @db.VarChar(255)
  address          String?
  npwp             String?           @db.VarChar(255)
  is_active        Boolean?          @default(true)
  created_at       DateTime          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime          @default(now()) @db.Timestamptz(6)
  consignment_days Int?
  items            items[]
  payables         payables[]
  purchase_orders  purchase_orders[]
  stock_lots       stock_lots[]
}

model tax_settings {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(255)
  rate         Decimal  @db.Decimal(5, 2)
  is_inclusive Boolean? @default(false)
  is_active    Boolean? @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)
}

model transaction_items {
  id               Int                      @id @default(autoincrement())
  transaction_id   String?                  @db.VarChar(255)
  item_id          Int?
  price            Decimal                  @db.Decimal(14, 2)
  qty              Int
  subtotal         Decimal                  @db.Decimal(14, 2)
  created_at       DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at       DateTime                 @default(now()) @db.Timestamptz(6)
  discount         Decimal                  @default(0) @db.Decimal(14, 2)
  cost_price       Decimal                  @default(0) @db.Decimal(14, 2)
  lot_consumptions stock_lot_consumptions[]
  items            items?                   @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "transaction_items_item_id_foreign")
  transactions     transactions?            @relation(fields: [transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "transaction_items_transaction_id_foreign")
}

model transactions {
  id                  String              @id @db.VarChar(255)
  user_id             Int?
  customer_id         Int?
  payment_type_id     Int?
  subtotal            Decimal             @db.Decimal(14, 2)
  tax_amount          Decimal?            @default(0) @db.Decimal(14, 2)
  discount_amount     Decimal?            @default(0) @db.Decimal(14, 2)
  total               Decimal             @db.Decimal(14, 2)
  payment_amount      Decimal             @db.Decimal(14, 2)
  change_amount       Decimal?            @default(0) @db.Decimal(14, 2)
  status              String?             @default("completed") @db.VarChar(255)
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  updated_at          DateTime            @default(now()) @db.Timestamptz(6)
  outlet              String?             @db.VarChar(255)
  refunds             Decimal?            @default(0) @db.Decimal(14, 2)
  net_sales           Decimal?            @default(0) @db.Decimal(14, 2)
  gratuity            Decimal?            @default(0) @db.Decimal(14, 2)
  notes               String?
  cashier_name        String?             @db.VarChar(255)
  customer_name       String?             @db.VarChar(255)
  customer_phone      String?             @db.VarChar(255)
  payment_method_name String?             @db.VarChar(255)
  event_type          String?             @db.VarChar(255)
  reason_of_refund    String?
  idempotency_key     String?             @unique(map: "transactions_idempotency_key_unique") @db.VarChar(255)
  external_ref        String?             @unique(map: "transactions_external_ref_unique") @db.VarChar(255)
  transaction_items   transaction_items[]
  customers           customers?          @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "transactions_customer_id_foreign")
  payment_types       payment_types?      @relation(fields: [payment_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "transactions_payment_type_id_foreign")
  users               users?              @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "transactions_user_id_foreign")
  void_items          void_items[]
}

model users {
  id                Int                 @id @default(autoincrement())
  name              String              @db.VarChar(255)
  email             String              @unique(map: "users_email_unique") @db.VarChar(255)
  password_hash     String              @db.VarChar(255)
  role              String?             @default("kasir") @db.VarChar(255)
  phone             String?             @db.VarChar(255)
  avatar            String?             @db.VarChar(255)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  expenses          expenses[]
  purchase_orders   purchase_orders[]
  stock_adjustments stock_adjustments[]
  transactions      transactions[]
  void_items        void_items[]
}

model void_items {
  id             Int           @id @default(autoincrement())
  transaction_id String?       @db.VarChar(255)
  item_id        Int?
  qty            Int
  refund_amount  Decimal       @db.Decimal(14, 2)
  reason         String        @db.VarChar(255)
  executed_by    Int?
  created_at     DateTime      @default(now()) @db.Timestamptz(6)
  updated_at     DateTime      @default(now()) @db.Timestamptz(6)
  users          users?        @relation(fields: [executed_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "void_items_executed_by_foreign")
  items          items?        @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "void_items_item_id_foreign")
  transactions   transactions? @relation(fields: [transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "void_items_transaction_id_foreign")
}

model User {
  id            String          @id
  name          String
  email         String          @unique
  emailVerified Boolean         @default(false)
  image         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  role          String?         @default("kasir")
  staffId       Int?
  accounts      Account[]
  notifications notifications[]
  sessions      Session[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model notifications {
  id           Int       @id @default(autoincrement())
  auth_user_id String
  title        String    @db.VarChar(255)
  message      String
  is_read      Boolean?  @default(false)
  category     String    @db.VarChar(50)
  type         String    @db.VarChar(50)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  user         User      @relation(fields: [auth_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([auth_user_id])
  @@index([is_read])
}
